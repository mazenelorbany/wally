{
  "name": "wally",
  "version": "0.1.0",
  "private": true,
  "description": "Wally — AI visual-merchandising compliance for GRB retail (TCC)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @wally/api exec prisma generate",
    "db:push": "pnpm --filter @wally/api exec prisma db push",
    "db:migrate": "pnpm --filter @wally/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @wally/api exec prisma studio",
    "db:seed": "pnpm --filter @wally/api exec tsx prisma/seed.ts",
    "db:seed:restore": "pnpm --filter @wally/api exec tsx prisma/seed-restore-myer.ts",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "eval": "pnpm --filter @wally/api exec tsx ../../tools/eval/run.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
