{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "composite": false,
    "sourceMap": true,
    "paths": {
      "@wally/types": ["./packages/types/src/index.ts"],
      "@wally/ui": ["./packages/ui/src/index.ts"],
      "@wally/sdk": ["./packages/sdk/src/index.ts"]
    }
  }
}
