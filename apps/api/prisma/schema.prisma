// Wally data model. Decisions baked in:
//  - org_id on every tenant-scoped table (multi-retailer from day one)
//  - rubrics are append-only versioned rows; verdicts FK a specific version
//  - ScoreJob table is the durable queue (claimed with SKIP LOCKED)
//  - verdicts stamped with model + rubric + prompt version (reproducible)
//  - magic-link tokens stored sha256-hashed, single-use

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 no longer accepts `url = env(...)` here. The connection URL lives
  // in prisma.config.ts (CLI) and PrismaService's PrismaPg adapter (runtime).
}

// ─────────────────────────────────────────── identity / tenancy

model Org {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Which promo wave is selling right now: 'AUTO' follows the TCC calendar
  // (odd months = Sale 1, even months = Sale 2), or pin 'SALE_1' / 'SALE_2',
  // or 'ALL' to put the whole catalog on sale.
  saleMode  String   @default("AUTO")
  createdAt DateTime @default(now())

  users      User[]
  stores     Store[]
  campaigns  Campaign[]
  projects   Project[]
  rubrics    Rubric[]
  submissions Submission[]
  fixtures      Fixture[]
  placements    Placement[]
  guideFixtures GuideFixture[]
  products      Product[]
  merchandise   Merchandise[]
  fixtureProducts FixtureProduct[]
  tasks         Task[]
  salesEntries  SalesEntry[]
  captures      FixtureCapture[]
  complianceSnapshots ComplianceSnapshot[]
  bulletins     Bulletin[]
  resources     Resource[]
  capturePhotos        FixtureCapturePhoto[]
  campaignQuestions    CampaignQuestion[]
  storeQuestionAnswers StoreQuestionAnswer[]
  storeReports         StoreReport[]
  checklistItems       GuideFixtureChecklistItem[]
  checklistTicks       StoreChecklistTick[]
  fixtureChecklistTemplates FixtureChecklistTemplate[]
}

enum Role {
  ADMIN
  REVIEWER
  STORE_MANAGER
  VIEWER // read-only: sees layouts, photos, and scores; cannot edit or upload
  SETUP_CREW // store-scoped; sees ONLY the floor plan + per-fixture setup reference
}

// A project is the top-level container an admin works in: a retail VM campaign
// (Myer) or a tradeshow stand setup (Ambiente). It owns its venues (stores),
// its guide (campaign), the floor-plan layout, and the verify-and-score flow.
enum ProjectKind {
  RETAIL
  TRADESHOW
}

model Project {
  id        String      @id @default(cuid())
  orgId     String
  name      String
  slug      String
  kind      ProjectKind @default(RETAIL)
  createdAt DateTime    @default(now())
  // Soft-delete: set when an admin archives the project, so it leaves the working
  // list but keeps its history (a typo'd name / wrong kind doesn't pollute forever).
  // Null = active.
  archivedAt DateTime?

  org       Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  stores    Store[]
  bulletins Bulletin[]
  fixtures  Fixture[]

  @@unique([orgId, slug])
  @@index([orgId])
}

model User {
  id        String   @id @default(cuid())
  orgId     String
  email     String   @unique
  name      String?
  role       Role     @default(REVIEWER)
  googleId   String?  @unique
  storeId    String?  // store managers belong to a store (set via magic-link)
  disabledAt DateTime? // deactivated by an admin — blocked from resolving a session
  // Who disabled this user (the acting admin), stamped on the false→true
  // transition and cleared on re-enable — a minimal who/when audit for the
  // deactivation lifecycle. Nullable + no FK relation kept deliberately light.
  disabledById String?
  createdAt  DateTime @default(now())
  // @default(now()) backfills existing rows on `db push` (the column is added
  // NOT NULL); @updatedAt keeps it current on every write thereafter.
  updatedAt  DateTime @default(now()) @updatedAt

  // Notification preference: should this user's task badge alert on new tasks?
  // Store managers toggle it in their settings; defaults on for everyone.
  notifyOnNewTask Boolean @default(true)

  // Notification preference: should this admin/reviewer receive the daily
  // "store still owes photos" chase email? Toggled in their Settings; defaults
  // on. ChaseService filters recipients by this so opting out actually mutes it.
  chaseEmails Boolean @default(true)

  org             Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store           Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  sessions        Session[]
  reviews         Review[]
  curatedPhotos   Photo[]   @relation("PhotoCurator")
  reviewedVerdicts Verdict[] @relation("VerdictReviewer")
  taskReads        TaskRead[]
  completedTasks   Task[]    @relation("TaskCompletedBy")
  assignedTasks    Task[]    @relation("TaskAssignedTo")
  requestedCaptures FixtureCapture[] @relation("CaptureRequestedBy")
  reviewedCaptures  FixtureCapture[] @relation("CaptureReviewedBy")
  capturedAttempts  FixtureCaptureAttempt[] @relation("AttemptCapturedBy")
  bulletinAcks      BulletinAck[]
  uploadedCapturePhotos FixtureCapturePhoto[] @relation("CapturePhotoUploadedBy")
  answeredQuestions     StoreQuestionAnswer[] @relation("AnswerAnsweredBy")
  submittedReports      StoreReport[]         @relation("ReportSubmittedBy")
  assignedReports       StoreReport[]         @relation("ReportAssignedBy")
  checkedTicks          StoreChecklistTick[]  @relation("TickCheckedBy")

  @@index([orgId])
  @@index([storeId])
}

model Session {
  id        String   @id // hex(randomBytes(32))
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Single-use, short-TTL. Token is only stored as a sha256 hash.
model MagicLinkToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  email     String
  orgId     String
  storeId   String?
  role      Role     @default(STORE_MANAGER)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}

// ─────────────────────────────────────────── retail structure

model Store {
  id          String   @id @default(cuid())
  orgId       String
  projectId   String?  // the project (venue group) this store belongs to
  name        String
  brand       String   // "House", "Robins Kitchen", "The Custom Chef"
  externalRef String?  // ReStore / Globe id
  region      String?  // segmentation: state / area, e.g. "NSW", "VIC"
  areaManager String?  // segmentation: the field manager who owns the store
  storeType   String?  // segmentation: "Full line" | "Express" | ...
  closedAt    DateTime? // set when the store is deactivated/retired (lifecycle); null = active
  createdAt   DateTime @default(now())

  org           Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  submissions   Submission[]
  storeFixtures StoreFixture[]
  managers      User[]
  placements    Placement[]
  tasks         Task[]
  salesEntries  SalesEntry[]
  captures      FixtureCapture[]
  bulletinAcks  BulletinAck[]
  questionAnswers StoreQuestionAnswer[]
  reports         StoreReport[]
  checklistTicks  StoreChecklistTick[]

  @@index([orgId])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model Campaign {
  id        String         @id @default(cuid())
  orgId     String
  projectId String?        // the project this guide belongs to
  key       String // "MSP2-2026"
  name      String
  status    CampaignStatus @default(DRAFT)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @default(now()) @updatedAt
  // Lifecycle audit trail. activatedAt/closedAt are stamped by the lifecycle
  // transitions (setActive/close/reopen) including the project-scoped bulk-close
  // branch; archivedAt is the soft-archive marker (archived campaigns are hidden
  // from the list but kept for historical analytics).
  activatedAt DateTime?
  closedAt    DateTime?
  archivedAt  DateTime?
  // When the guide (floor plans + fixture sheets) was last published to stores.
  // Publishing stamps this and fans out an UPLOAD_PHOTO task to every store in
  // the campaign's project, so managers are notified the layout is ready.
  publishedAt DateTime?

  org         Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  rubrics     Rubric[]
  submissions Submission[]
  placements    Placement[]
  guideFixtures GuideFixture[]
  tasks         Task[]
  salesEntries  SalesEntry[]
  captures      FixtureCapture[]
  complianceSnapshots ComplianceSnapshot[]
  campaignQuestions CampaignQuestion[]
  questionAnswers   StoreQuestionAnswer[]
  storeReports      StoreReport[]
  checklistTicks    StoreChecklistTick[]

  @@unique([orgId, key])
  @@index([orgId])
}

// How a ComplianceSnapshot row was written. The nightly cron is the canonical
// author (CRON); an admin "capture now" is MANUAL. The write rule keeps a cron
// row canonical for its day: a MANUAL capture never overwrites a CRON row (so a
// mid-day manual capture can't clobber the authoritative end-of-day value).
enum SnapshotSource {
  CRON
  MANUAL
}

// A daily point-in-time rollup of a campaign's compliance, so the dashboard can
// chart pass-rate / completion over time. Written by the snapshot cron (and an
// admin "capture now" button); upsert-keyed by (campaignId, dateKey) so one run
// per day is idempotent.
model ComplianceSnapshot {
  id          String   @id @default(cuid())
  orgId       String
  campaignId  String
  dateKey     String // 'YYYY-MM-DD' (UTC) — one snapshot per campaign per day
  capturedAt  DateTime @default(now())
  // Who wrote this point. Existing rows default to CRON (the canonical author),
  // so the additive column needs no backfill.
  source      SnapshotSource @default(CRON)
  storeCount  Int
  onTrack     Int // stores in perfect + good
  needsReview Int
  failing     Int // stores in not_good
  incomplete  Int
  submitted   Int // fixtures photographed
  expected    Int // applicable fixtures
  passing     Int // fixtures scored perfect/good

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, dateKey])
  @@index([campaignId, capturedAt])
}

// Append-only. Editing publishes a new (campaignId, fixtureKey, version) row.
model Rubric {
  id             String   @id @default(cuid())
  orgId          String
  campaignId     String
  fixtureKey     String   // "storefront" | "vm_table" | "doorbuster"
  version        Int
  criteria       Json     // [{ id, kind, critical, text }]
  rollupRule     Json     @default("{\"not_good_if_any_critical_fails\":true,\"good_if_only_noncritical_fails\":true}")
  referenceKey   String?  // storage key of the reference/standard image
  // The live grading version for (campaignId, fixtureKey). Exactly one row per
  // pair should be active; the scorer resolves it. Seeded/legacy rows are all
  // false — the scorer falls back to highest version when none is flagged, so no
  // data migration is needed.
  active         Boolean  @default(false)
  createdAt      DateTime @default(now())

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  verdicts Verdict[]

  @@unique([campaignId, fixtureKey, version])
  @@index([orgId])
}

// Per-store applicability ("we don't have VM table 3"). order drives the checklist.
model StoreFixture {
  id         String  @id @default(cuid())
  storeId    String
  campaignId String
  fixtureKey String
  label      String  // "Storefront", "VM Table 1 · Le Connoisseur"
  applicable Boolean @default(true)
  order      Int     @default(0)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, campaignId, fixtureKey])
  @@index([storeId, campaignId])
}

// ─────────────────────────────────────────── submissions / scoring

enum SubmissionStatus {
  PENDING
  PARTIAL
  SUBMITTED
}

model Submission {
  id          String           @id @default(cuid())
  orgId       String
  storeId     String
  campaignId  String
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime?
  createdAt   DateTime         @default(now())

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  photos   Photo[]

  @@unique([storeId, campaignId])
  @@index([orgId])
}

enum PhotoStatus {
  UPLOADED
  SCORING
  SCORED
  FAILED
}

model Photo {
  id           String      @id @default(cuid())
  submissionId String
  fixtureKey   String
  storageKey   String      // key in StorageService
  status       PhotoStatus @default(UPLOADED)
  width        Int?
  height       Int?
  bestInClass  Boolean     @default(false) // reviewer-flagged exemplar execution
  // Audit for the best-in-class curation toggle: who last flipped it and when.
  curatedById  String?
  curatedAt    DateTime?
  createdAt    DateTime    @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  job        ScoreJob?
  verdict    Verdict?
  curatedBy  User?      @relation("PhotoCurator", fields: [curatedById], references: [id])

  @@index([submissionId])
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// The durable queue. Worker claims with SELECT ... FOR UPDATE SKIP LOCKED.
model ScoreJob {
  id        String    @id @default(cuid())
  photoId   String    @unique
  status    JobStatus @default(PENDING)
  attempts  Int       @default(0)
  lastError String?
  lockedAt  DateTime?
  runAfter  DateTime  @default(now()) // backoff schedule
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([status, runAfter])
}

enum Overall {
  PERFECT
  GOOD
  NOT_GOOD
  NEEDS_REVIEW
}

model Verdict {
  id            String   @id @default(cuid())
  photoId       String   @unique
  rubricId      String
  overall       Overall
  needsReview   Boolean
  confidence    Float
  modelId       String
  promptVersion String
  results       Json     // [{ id, verdict, confidence, evidence }]
  // Audit for human review: who last reviewed/overrode this verdict, and when
  // the row last changed (set on every override).
  lastReviewedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  photo        Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  rubric       Rubric   @relation(fields: [rubricId], references: [id])
  reviews      Review[]
  lastReviewedBy User?  @relation("VerdictReviewer", fields: [lastReviewedById], references: [id])

  @@index([rubricId])
}

enum ReviewAction {
  CONFIRM
  OVERRIDE
  ESCALATE
}

model Review {
  id          String       @id @default(cuid())
  verdictId   String
  criterionId String? // null = whole-fixture action
  action      ReviewAction
  fromVerdict String?
  toVerdict   String?
  reason      String?
  reviewerId  String
  createdAt   DateTime     @default(now())

  verdict  Verdict @relation(fields: [verdictId], references: [id], onDelete: Cascade)
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@index([verdictId])
}

// ═══════════════════════════════════════════ CREATE GUIDE platform
// A VM guide (Campaign) places Fixtures on each Store's floor plan (Placement),
// and each fixture in a guide (GuideFixture) carries notes + example images +
// the Products merchandised on it. This is the keystone the money-map and
// dashboards build on. Compliance pillar (above) keeps its own models for now.

// Canonical fixture in the library (e.g. "TCC Wall Bay 1", "Cookset Bulkstack").
model Fixture {
  id         String   @id @default(cuid())
  orgId      String
  // The project (venue group) that owns this fixture. Null = a SHARED fixture
  // visible in every project. Myer and Ambiente keep their own fixtures so the
  // library and floor-plan palette never mix one entity's fixtures into another.
  projectId  String?
  name       String
  kind       String   @default("bay") // bay | table | stand | window | dais | trolley
  department String? // Myer department: "The Custom Chef" | "The Cook Shop"
  // Library-level "what good looks like" reference image. Guides that have no
  // example image of their own fall back to this, so a fixture carries one
  // canonical reference instead of re-uploading it per store.
  referenceKey     String?
  referenceCaption String?
  // Library-level DEFAULT guide content the fixture carries: VM notes + ordered
  // instructions ([{id,text}]) + the checklistTemplate rows below. The first
  // time a task opens this fixture, the new GuideFixture inherits all three — so
  // the standard for a fixture type is authored once and flows into every task.
  defaultNotes        String  @default("")
  defaultInstructions Json?
  createdAt  DateTime @default(now())
  archivedAt DateTime? // soft-delete: hidden from the library, placements kept

  org             Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // SetNull (not Cascade): archiving/deleting a project turns its fixtures into
  // shared fixtures rather than destroying library entries other guides may use.
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  placements      Placement[]
  guideFixtures   GuideFixture[]
  captures        FixtureCapture[]
  defaultProducts FixtureProduct[]
  checklistTemplate FixtureChecklistTemplate[]

  @@unique([orgId, name])
  @@index([orgId])
  @@index([orgId, projectId])
}

// A library-level default checklist item for a fixture type. Copied into a
// GuideFixture's checklist (GuideFixtureChecklistItem) the first time a task
// opens that fixture, so a fixture's standard checklist is authored once.
model FixtureChecklistTemplate {
  id         String    @id @default(cuid())
  orgId      String
  fixtureId  String
  label      String
  required   Boolean   @default(false)
  order      Int       @default(0)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  org     Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([fixtureId])
}

// A fixture placed on one store's floor plan for one guide (its x/y/w/h on the
// canvas + per-store applicability — the "we don't have this" lives here too).
model Placement {
  id         String  @id @default(cuid())
  orgId      String
  storeId    String
  campaignId String
  fixtureId  String
  label      String
  x          Float   @default(0)
  y          Float   @default(0)
  w          Float   @default(120)
  h          Float   @default(80)
  rotation   Float   @default(0)
  applicable Boolean @default(true)
  order      Int     @default(0)
  // Money map: illustrative period sales for this fixture in this store. Null
  // until a real POS feed lands; seeded with sample figures for the demo.
  revenue    Float?
  units      Int?

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fixture  Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@unique([storeId, campaignId, fixtureId])
  @@index([campaignId, storeId])
}

// A fixture's instruction sheet within a guide: rich-text notes + example
// images + the products merchandised on it (the right rail in the demo).
model GuideFixture {
  id         String   @id @default(cuid())
  orgId      String
  campaignId String
  fixtureId  String
  notes      String   @default("") // rich text / markdown
  // Ordered structured setup steps, distinct from the free-form `notes`:
  // [{ id, text }]. Rendered as a numbered list to the manager + setup crew.
  instructions Json?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  org           Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fixture       Fixture        @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  merchandise   Merchandise[]
  exampleImages ExampleImage[]
  checklistItems GuideFixtureChecklistItem[]

  @@unique([campaignId, fixtureId])
  @@index([campaignId])
}

// A per-fixture checklist item the store manager ticks while filling the report
// (e.g. "Hero SKU at eye level"). Authored by the admin on the guide fixture;
// ticks are recorded per store in StoreChecklistTick. Soft-archived once ticked.
model GuideFixtureChecklistItem {
  id             String    @id @default(cuid())
  orgId          String
  guideFixtureId String
  label          String
  required       Boolean   @default(false)
  order          Int       @default(0)
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())

  org          Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  guideFixture GuideFixture @relation(fields: [guideFixtureId], references: [id], onDelete: Cascade)
  ticks        StoreChecklistTick[]

  @@index([guideFixtureId, order])
}

// One store's tick of one checklist item. Keyed (storeId, itemId) so a store has
// at most one tick per item. campaignId denormalised for the report read.
model StoreChecklistTick {
  id          String   @id @default(cuid())
  orgId       String
  storeId     String
  campaignId  String
  itemId      String
  checked     Boolean  @default(true)
  checkedById String?
  checkedAt   DateTime @default(now())
  // Set when the AI auto-ticked this item (high-confidence PASS) rather than a
  // person. Only non-required items are ever auto-ticked; the manager can untick.
  aiTicked     Boolean @default(false)
  aiConfidence Float?

  org       Org                       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store     Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign  Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  item      GuideFixtureChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  checkedBy User?                     @relation("TickCheckedBy", fields: [checkedById], references: [id], onDelete: SetNull)

  @@unique([storeId, itemId])
  @@index([storeId, campaignId])
}

// Product catalog (connected to the buying/allocation source).
model Product {
  id        String   @id @default(cuid())
  orgId     String
  sku       String
  name      String   // the VM-guide label (e.g. "LE CON MINI CASS 160ML TEA")
  webTitle  String?  // full retail title from baccarat.com.au
  brand     String?
  range     String?  // Baccarat range: "Le Connoisseur", "Nook", "Iconix"…
  category  String?
  color     String?
  imageUrl  String?
  rrp       Float?   // recommended retail price
  salePrice Float?   // current sale/ticket price — the per-unit price sales log against
  // Promo-wave membership: 'SALE_1' | 'SALE_2' | 'BOTH'; null = never on promo.
  // The product sells at salePrice only when its wave matches Org.saleMode.
  saleWave  String?
  // Gift-with-purchase: offered free alongside a qualifying purchase.
  gwp       Boolean  @default(false)
  // The qualifying product this gift is free WITH (self-relation). Deleting
  // the qualifying product orphans the gift (SetNull) rather than deleting it.
  gwpWithId String?
  createdAt DateTime @default(now())
  // Soft-delete: an archived product leaves the working catalog (and the picker)
  // but its merchandise placements + sales history stay intact. Null = active.
  archivedAt DateTime?

  org             Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  merchandise     Merchandise[]
  salesEntries    SalesEntry[]
  fixtureDefaults FixtureProduct[]
  gwpWith         Product?         @relation("GwpPair", fields: [gwpWithId], references: [id], onDelete: SetNull)
  gwpGifts        Product[]        @relation("GwpPair")

  @@unique([orgId, sku])
  @@index([orgId])
}

// A default product on a library fixture — the reusable "what goes on this
// fixture" set (e.g. a Nook cookware setup). Copied onto a guide-fixture's
// merchandise when the author chooses to pre-populate, rather than start blank.
model FixtureProduct {
  id        String   @id @default(cuid())
  orgId     String
  fixtureId String
  productId String
  row       String? // optional planogram row grouping, mirrors Merchandise.row
  order     Int      @default(0)
  createdAt DateTime @default(now())

  org     Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([fixtureId, productId])
  @@index([fixtureId])
}

// A product merchandised onto a guide-fixture (with a row grouping like the demo).
model Merchandise {
  id             String   @id @default(cuid())
  orgId          String
  guideFixtureId String
  productId      String
  row            String?  // "Top rack", "New row", ...
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  org          Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  guideFixture GuideFixture @relation(fields: [guideFixtureId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([guideFixtureId])
}

// The VM-team example image(s) for a guide-fixture ("what good looks like").
model ExampleImage {
  id             String   @id @default(cuid())
  orgId          String
  guideFixtureId String
  storageKey     String
  caption        String?
  bestInClass    Boolean  @default(false)
  createdAt      DateTime @default(now())

  guideFixture GuideFixture @relation(fields: [guideFixtureId], references: [id], onDelete: Cascade)

  @@index([guideFixtureId])
}

// ═══════════════════════════════════════════ STORE-MANAGER workspace
// Tasks an admin assigns to a store (its manager): capture a photo, log sales,
// or a general ask. The manager's home shows OPEN tasks; the unread badge is
// PER-USER via TaskRead (one row per task per reader), so one co-manager opening
// Tasks no longer clears another's badge. SalesEntry is the manager's per-product
// sales log for a campaign period; it rolls up to the fixture (and the Money Map).

enum TaskKind {
  UPLOAD_PHOTO // capture/upload a fixture photo into the checklist
  LOG_SALES // log sales for the period
  GENERAL // free-form ask
}

enum TaskStatus {
  OPEN
  DONE
}

model Task {
  id          String     @id @default(cuid())
  orgId       String
  storeId     String // the store (its manager) the task is assigned to
  campaignId  String?
  kind        TaskKind   @default(GENERAL)
  status      TaskStatus @default(OPEN)
  title       String
  body        String? // what the admin is asking for
  fixtureKey  String? // for UPLOAD_PHOTO: which fixture
  dueAt       DateTime?
  // Lifecycle audit: who completed it (stamped on completeTask, cleared on
  // reopen) and the optional individual it was assigned to (store-level by
  // default; assignedToId narrows it to one manager).
  completedById String?
  assignedToId  String?
  completedAt DateTime?
  createdAt   DateTime   @default(now())

  org      Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  completedBy User?   @relation("TaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  assignedTo  User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  reads       TaskRead[]

  @@index([storeId, status])
  @@index([orgId])
}

// One reader's "I've seen this task" receipt — the per-user notification badge.
// Keyed (taskId, userId): the unseen-badge count is OPEN tasks for the user's
// store with no TaskRead for THAT user, so a co-manager opening Tasks never
// clears another manager's badge (the per-store seenAt class of bug, fixed).
model TaskRead {
  id     String   @id @default(cuid())
  taskId String
  userId String
  seenAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

// One running sales tally per (store, campaign, product): units sold × the
// unit price snapshot = revenue. `fixtureId` is denormalised from the product's
// placement so the Money Map rolls up by fixture with a simple groupBy.
model SalesEntry {
  id         String   @id @default(cuid())
  orgId      String
  storeId    String
  campaignId String
  productId  String
  fixtureId  String?
  units      Int      @default(0)
  unitPrice  Float    @default(0) // price snapshot at log time (set once, on first log of the day)
  revenue    Float    @default(0) // units × unitPrice, stored for fast rollups
  soldOn     DateTime @default(now()) @db.Date // the sale DAY (date-only); one entry per product per day
  loggedById String? // the user who last logged this day's units (actor audit)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, campaignId, productId, soldOn])
  @@index([storeId, campaignId, soldOn])
  @@index([campaignId, fixtureId])
}

// The store-manager compliance loop on the floor map. One row per
// (store, campaign, fixture): whether a photo is wanted this sale, the photo
// the manager submitted, and the AI verdict from comparing it to the guide's
// reference image + VM notes. Distinct from the legacy Submission/Photo pipeline
// (which is keyed by generic fixtureKey) — this is fixture-on-the-floor-plan.
enum CaptureVerdict {
  PASS
  NEEDS_REVIEW
  FAIL
}

model FixtureCapture {
  id         String          @id @default(cuid())
  orgId      String
  storeId    String
  campaignId String
  fixtureId  String
  needsPhoto Boolean         @default(true) // requested this sale / by a reviewer
  storageKey String? // the manager's uploaded photo (CURRENT — latest shot)
  uploadedAt DateTime?
  verdict    CaptureVerdict? // the AI verdict for the CURRENT photo
  aiNotes    String? // the model's compare notes
  aiIssues   Json? // [{label,fix,severity,box:{x,y,w,h}}] — defects + on-image boxes
  confidence Float?
  modelId    String? // e.g. "gemini-2.5-flash" or "stub"
  scoredAt   DateTime?
  // ----- reviewer override / request loop (REVIEWER/ADMIN) -----
  // A reviewer can REQUEST a re-shoot (needsPhoto=true + stamp), or OVERRIDE the
  // AI verdict with a human decision. The EFFECTIVE verdict the floor/money-map/UI
  // shows is `overrideVerdict ?? verdict` — the human call supersedes the model.
  requestedById  String? // reviewer who asked for a fresh photo
  requestedAt    DateTime?
  reviewedById   String? // reviewer who set the override
  reviewedAt     DateTime?
  overrideVerdict CaptureVerdict? // human decision that supersedes `verdict`
  overrideNote    String? // optional reviewer rationale for the override
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fixture  Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  requestedBy User? @relation("CaptureRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy  User? @relation("CaptureReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  attempts FixtureCaptureAttempt[]
  photos   FixtureCapturePhoto[]

  @@unique([storeId, campaignId, fixtureId])
  @@index([storeId, campaignId])
}

// One preserved shot in a fixture's capture history. `FixtureCapture` is the
// CURRENT pointer (latest photo + its AI verdict); every upload+score also writes
// one immutable FixtureCaptureAttempt so a FAIL→reshoot→PASS sequence is never
// erased (mirrors the SalesEntry day-snapshot pattern — the current row is the
// latest, the history rows preserve every prior state).
model FixtureCaptureAttempt {
  id           String          @id @default(cuid())
  orgId        String
  captureId    String
  storageKey   String // the photo bytes for THIS shot
  verdict      CaptureVerdict? // the AI verdict scored for this shot
  aiNotes      String?
  aiIssues     Json? // [{label,fix,severity,box:{x,y,w,h}}] — defects + on-image boxes
  confidence   Float?
  modelId      String?
  capturedById String? // the manager who took this shot
  capturedAt   DateTime        @default(now())

  capture    FixtureCapture @relation(fields: [captureId], references: [id], onDelete: Cascade)
  capturedBy User?          @relation("AttemptCapturedBy", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([captureId, capturedAt])
}

// One photo in a fixture capture's gallery. A capture can hold several photos
// (multiple angles of one display, e.g. "front and back of the bulk stack").
// FixtureCapture.storageKey stays the COVER pointer (the lowest-order, non-
// archived photo) so every existing single-photo reader keeps working; this child
// table is the full set. Distinct from FixtureCaptureAttempt (the immutable
// score/reshoot history) — a row here is a currently-displayed gallery member.
model FixtureCapturePhoto {
  id           String    @id @default(cuid())
  orgId        String
  captureId    String
  storageKey   String
  order        Int       @default(0)
  aiIssues     Json? // per-photo defects [{label,fix,severity,box,photoIndex}]
  uploadedById String?
  uploadedAt   DateTime  @default(now())
  archivedAt   DateTime? // soft-remove from the gallery; history attempts untouched

  org        Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  capture    FixtureCapture @relation(fields: [captureId], references: [id], onDelete: Cascade)
  uploadedBy User?          @relation("CapturePhotoUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([captureId, order])
}

// ═══════════════════════════════════════════ STORE REPORTS
// A campaign report = the store's fixture captures (AI-scored photo steps, above)
// PLUS an admin-defined set of extra questions (text / yes-no / note), wrapped in
// a submittable StoreReport (draft → submitted) with a total score frozen at
// submit and a cached AI summary. Supersedes the legacy Submission/Photo/Verdict
// envelope — the report reads FixtureCapture, NEVER Photo/Verdict.

enum CampaignQuestionType {
  SHORT_TEXT
  YES_NO
  LONG_NOTE
}

// An admin-authored, ordered extra question on a campaign's report (e.g. "Who
// completed this task?", "Any difficulties?"). Soft-archived (archivedAt) when it
// already has answers, so removing a question keeps the answered history.
model CampaignQuestion {
  id         String               @id @default(cuid())
  orgId      String
  campaignId String
  order      Int                  @default(0)
  label      String
  type       CampaignQuestionType @default(SHORT_TEXT)
  required   Boolean              @default(false)
  allowNA    Boolean              @default(false)
  archivedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @default(now()) @updatedAt

  org      Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  answers  StoreQuestionAnswer[]

  @@index([campaignId, order])
}

// One store's answer to one CampaignQuestion. campaignId is denormalised so the
// report read is a single (storeId, campaignId) query without joining through the
// question. valueBool is set for YES_NO; valueText for SHORT_TEXT / LONG_NOTE.
model StoreQuestionAnswer {
  id           String   @id @default(cuid())
  orgId        String
  storeId      String
  campaignId   String
  questionId   String
  valueText    String?
  valueBool    Boolean?
  isNA         Boolean  @default(false)
  answeredById String?
  answeredAt   DateTime @default(now())

  org        Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store      Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  question   CampaignQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answeredBy User?            @relation("AnswerAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)

  @@unique([storeId, questionId])
  @@index([storeId, campaignId])
}

enum StoreReportStatus {
  DRAFT // legacy: a row that exists without an explicit assignment (kept for back-compat)
  PENDING // sent to the store, not started yet
  IN_PROGRESS // the manager has started filling it (a photo/answer/tick exists)
  SUBMITTED
  REOPENED // a reviewer requested a re-shoot after submit; the store re-submits
}

// The submittable envelope over a store's work for a campaign: status, the total
// score frozen at submit (pass-rate % across applicable fixtures), and the cached
// AI prose summary (keyed by aiSummaryInputHash so a regenerate is skipped when
// inputs are unchanged). Reads FixtureCapture; NOT the legacy Submission/Photo.
model StoreReport {
  id                 String            @id @default(cuid())
  orgId              String
  storeId            String
  campaignId         String
  status             StoreReportStatus @default(DRAFT)
  // "Sent" record: an admin assigned this report to the store.
  assignedAt         DateTime?
  assignedById       String?
  dueAt              DateTime?
  startedAt          DateTime? // first manager edit (PENDING → IN_PROGRESS)
  submittedAt        DateTime?
  submittedById      String?
  totalScore         Float? // pass-rate % frozen at submit
  aiSummary          String?
  summaryModelId     String?
  summarizedAt       DateTime?
  aiSummaryInputHash String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt

  org         Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submittedBy User?    @relation("ReportSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  assignedBy  User?    @relation("ReportAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([storeId, campaignId])
  @@index([orgId, campaignId])
}

// ═══════════════════════════════════════════ BULLETINS
// The per-sale memo that ships with each promotion (like the real "BULLETIN 89"):
// an admin authors it for a project (title + body + key dates + an optional PDF/
// image attachment), publishes it, and every store manager in the project must
// read + acknowledge it. A feed (newest first; pin the important ones).

model Bulletin {
  id             String    @id @default(cuid())
  orgId          String
  projectId      String
  campaignId     String? // the sale this belongs to (the project's active campaign)
  title          String
  body           String    @default("") // markdown
  pinned         Boolean   @default(false)
  startsAt       DateTime?
  endsAt         DateTime?
  attachmentKey  String? // storage key of the attached PDF / image
  attachmentName String?
  publishedAt    DateTime? // null = draft
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  org     Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  acks    BulletinAck[]

  @@index([projectId])
  @@index([orgId])
}

// One store manager's acknowledgement of a bulletin (the read receipt).
// Keyed per USER, not per store: "every store manager must read + acknowledge",
// so one co-manager's ack must not clear the must-read for the others. storeId is
// kept on the row for roster grouping / context (which venue the manager owns).
model BulletinAck {
  id             String   @id @default(cuid())
  bulletinId     String
  storeId        String
  userId         String
  acknowledgedAt DateTime @default(now())

  bulletin Bulletin @relation(fields: [bulletinId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bulletinId, userId])
  @@index([bulletinId])
}

// A training / reference item in the org's resource library. Org-wide (every
// store sees the same library), filed under a two-level topic → sub-topic
// taxonomy, no read receipts. Carries EITHER an uploaded file (attachmentKey)
// OR an external link (url).
model Resource {
  id             String   @id @default(cuid())
  orgId          String
  title          String
  description    String   @default("")
  category       String   @default("General") // TOPIC — the top-level grouping
  subtopic       String   @default("") // SUB-TOPIC within the topic ("" = none)
  url            String? // external link (video, doc, brand site)
  attachmentKey  String? // storage key of an uploaded PDF / image / doc
  attachmentName String?
  pinned         Boolean  @default(false)
  order          Int      @default(0) // manual sort within a sub-topic
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}
