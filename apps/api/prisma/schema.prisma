// Wally data model. Decisions baked in:
//  - org_id on every tenant-scoped table (multi-retailer from day one)
//  - rubrics are append-only versioned rows; verdicts FK a specific version
//  - ScoreJob table is the durable queue (claimed with SKIP LOCKED)
//  - verdicts stamped with model + rubric + prompt version (reproducible)
//  - magic-link tokens stored sha256-hashed, single-use

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 no longer accepts `url = env(...)` here. The connection URL lives
  // in prisma.config.ts (CLI) and PrismaService's PrismaPg adapter (runtime).
}

// ─────────────────────────────────────────── identity / tenancy

model Org {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users      User[]
  stores     Store[]
  campaigns  Campaign[]
  projects   Project[]
  rubrics    Rubric[]
  submissions Submission[]
  fixtures      Fixture[]
  placements    Placement[]
  guideFixtures GuideFixture[]
  products      Product[]
  merchandise   Merchandise[]
  fixtureProducts FixtureProduct[]
  tasks         Task[]
  salesEntries  SalesEntry[]
  captures      FixtureCapture[]
  complianceSnapshots ComplianceSnapshot[]
  bulletins     Bulletin[]
}

enum Role {
  ADMIN
  REVIEWER
  STORE_MANAGER
  VIEWER // read-only: sees layouts, photos, and scores; cannot edit or upload
}

// A project is the top-level container an admin works in: a retail VM campaign
// (Myer) or a tradeshow stand setup (Ambiente). It owns its venues (stores),
// its guide (campaign), the floor-plan layout, and the verify-and-score flow.
enum ProjectKind {
  RETAIL
  TRADESHOW
}

model Project {
  id        String      @id @default(cuid())
  orgId     String
  name      String
  slug      String
  kind      ProjectKind @default(RETAIL)
  createdAt DateTime    @default(now())

  org       Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  stores    Store[]
  bulletins Bulletin[]

  @@unique([orgId, slug])
  @@index([orgId])
}

model User {
  id        String   @id @default(cuid())
  orgId     String
  email     String   @unique
  name      String?
  role       Role     @default(REVIEWER)
  googleId   String?  @unique
  storeId    String?  // store managers belong to a store (set via magic-link)
  disabledAt DateTime? // deactivated by an admin — blocked from resolving a session
  createdAt  DateTime @default(now())

  org      Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  sessions Session[]
  reviews  Review[]

  @@index([orgId])
  @@index([storeId])
}

model Session {
  id        String   @id // hex(randomBytes(32))
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Single-use, short-TTL. Token is only stored as a sha256 hash.
model MagicLinkToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  email     String
  orgId     String
  storeId   String?
  role      Role     @default(STORE_MANAGER)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}

// ─────────────────────────────────────────── retail structure

model Store {
  id          String   @id @default(cuid())
  orgId       String
  projectId   String?  // the project (venue group) this store belongs to
  name        String
  brand       String   // "House", "Robins Kitchen", "The Custom Chef"
  externalRef String?  // ReStore / Globe id
  region      String?  // segmentation: state / area, e.g. "NSW", "VIC"
  areaManager String?  // segmentation: the field manager who owns the store
  storeType   String?  // segmentation: "Full line" | "Express" | ...
  createdAt   DateTime @default(now())

  org           Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  submissions   Submission[]
  storeFixtures StoreFixture[]
  managers      User[]
  placements    Placement[]
  tasks         Task[]
  salesEntries  SalesEntry[]
  captures      FixtureCapture[]
  bulletinAcks  BulletinAck[]

  @@index([orgId])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model Campaign {
  id        String         @id @default(cuid())
  orgId     String
  projectId String?        // the project this guide belongs to
  key       String // "MSP2-2026"
  name      String
  status    CampaignStatus @default(DRAFT)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime       @default(now())

  org         Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  rubrics     Rubric[]
  submissions Submission[]
  placements    Placement[]
  guideFixtures GuideFixture[]
  tasks         Task[]
  salesEntries  SalesEntry[]
  captures      FixtureCapture[]
  complianceSnapshots ComplianceSnapshot[]

  @@unique([orgId, key])
  @@index([orgId])
}

// A daily point-in-time rollup of a campaign's compliance, so the dashboard can
// chart pass-rate / completion over time. Written by the snapshot cron (and an
// admin "capture now" button); upsert-keyed by (campaignId, dateKey) so one run
// per day is idempotent.
model ComplianceSnapshot {
  id          String   @id @default(cuid())
  orgId       String
  campaignId  String
  dateKey     String // 'YYYY-MM-DD' (UTC) — one snapshot per campaign per day
  capturedAt  DateTime @default(now())
  storeCount  Int
  onTrack     Int // stores in perfect + good
  needsReview Int
  failing     Int // stores in not_good
  incomplete  Int
  submitted   Int // fixtures photographed
  expected    Int // applicable fixtures
  passing     Int // fixtures scored perfect/good

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, dateKey])
  @@index([campaignId, capturedAt])
}

// Append-only. Editing publishes a new (campaignId, fixtureKey, version) row.
model Rubric {
  id             String   @id @default(cuid())
  orgId          String
  campaignId     String
  fixtureKey     String   // "storefront" | "vm_table" | "doorbuster"
  version        Int
  criteria       Json     // [{ id, kind, critical, text }]
  rollupRule     Json     @default("{\"not_good_if_any_critical_fails\":true,\"good_if_only_noncritical_fails\":true}")
  referenceKey   String?  // storage key of the reference/standard image
  createdAt      DateTime @default(now())

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  verdicts Verdict[]

  @@unique([campaignId, fixtureKey, version])
  @@index([orgId])
}

// Per-store applicability ("we don't have VM table 3"). order drives the checklist.
model StoreFixture {
  id         String  @id @default(cuid())
  storeId    String
  campaignId String
  fixtureKey String
  label      String  // "Storefront", "VM Table 1 · Le Connoisseur"
  applicable Boolean @default(true)
  order      Int     @default(0)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, campaignId, fixtureKey])
  @@index([storeId, campaignId])
}

// ─────────────────────────────────────────── submissions / scoring

enum SubmissionStatus {
  PENDING
  PARTIAL
  SUBMITTED
}

model Submission {
  id          String           @id @default(cuid())
  orgId       String
  storeId     String
  campaignId  String
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime?
  createdAt   DateTime         @default(now())

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  photos   Photo[]

  @@unique([storeId, campaignId])
  @@index([orgId])
}

enum PhotoStatus {
  UPLOADED
  SCORING
  SCORED
  FAILED
}

model Photo {
  id           String      @id @default(cuid())
  submissionId String
  fixtureKey   String
  storageKey   String      // key in StorageService
  status       PhotoStatus @default(UPLOADED)
  width        Int?
  height       Int?
  bestInClass  Boolean     @default(false) // reviewer-flagged exemplar execution
  createdAt    DateTime    @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  job        ScoreJob?
  verdict    Verdict?

  @@index([submissionId])
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// The durable queue. Worker claims with SELECT ... FOR UPDATE SKIP LOCKED.
model ScoreJob {
  id        String    @id @default(cuid())
  photoId   String    @unique
  status    JobStatus @default(PENDING)
  attempts  Int       @default(0)
  lastError String?
  lockedAt  DateTime?
  runAfter  DateTime  @default(now()) // backoff schedule
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([status, runAfter])
}

enum Overall {
  PERFECT
  GOOD
  NOT_GOOD
  NEEDS_REVIEW
}

model Verdict {
  id            String   @id @default(cuid())
  photoId       String   @unique
  rubricId      String
  overall       Overall
  needsReview   Boolean
  confidence    Float
  modelId       String
  promptVersion String
  results       Json     // [{ id, verdict, confidence, evidence }]
  createdAt     DateTime @default(now())

  photo   Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  rubric  Rubric   @relation(fields: [rubricId], references: [id])
  reviews Review[]

  @@index([rubricId])
}

enum ReviewAction {
  CONFIRM
  OVERRIDE
  ESCALATE
}

model Review {
  id          String       @id @default(cuid())
  verdictId   String
  criterionId String? // null = whole-fixture action
  action      ReviewAction
  fromVerdict String?
  toVerdict   String?
  reason      String?
  reviewerId  String
  createdAt   DateTime     @default(now())

  verdict  Verdict @relation(fields: [verdictId], references: [id], onDelete: Cascade)
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@index([verdictId])
}

// ═══════════════════════════════════════════ CREATE GUIDE platform
// A VM guide (Campaign) places Fixtures on each Store's floor plan (Placement),
// and each fixture in a guide (GuideFixture) carries notes + example images +
// the Products merchandised on it. This is the keystone the money-map and
// dashboards build on. Compliance pillar (above) keeps its own models for now.

// Canonical fixture in the library (e.g. "TCC Wall Bay 1", "Cookset Bulkstack").
model Fixture {
  id         String   @id @default(cuid())
  orgId      String
  name       String
  kind       String   @default("bay") // bay | table | stand | window | dais | trolley
  department String? // Myer department: "The Custom Chef" | "The Cook Shop"
  createdAt  DateTime @default(now())
  archivedAt DateTime? // soft-delete: hidden from the library, placements kept

  org             Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  placements      Placement[]
  guideFixtures   GuideFixture[]
  captures        FixtureCapture[]
  defaultProducts FixtureProduct[]

  @@unique([orgId, name])
  @@index([orgId])
}

// A fixture placed on one store's floor plan for one guide (its x/y/w/h on the
// canvas + per-store applicability — the "we don't have this" lives here too).
model Placement {
  id         String  @id @default(cuid())
  orgId      String
  storeId    String
  campaignId String
  fixtureId  String
  label      String
  x          Float   @default(0)
  y          Float   @default(0)
  w          Float   @default(120)
  h          Float   @default(80)
  rotation   Float   @default(0)
  applicable Boolean @default(true)
  order      Int     @default(0)
  // Money map: illustrative period sales for this fixture in this store. Null
  // until a real POS feed lands; seeded with sample figures for the demo.
  revenue    Float?
  units      Int?

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fixture  Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@unique([storeId, campaignId, fixtureId])
  @@index([campaignId, storeId])
}

// A fixture's instruction sheet within a guide: rich-text notes + example
// images + the products merchandised on it (the right rail in the demo).
model GuideFixture {
  id         String   @id @default(cuid())
  orgId      String
  campaignId String
  fixtureId  String
  notes      String   @default("") // rich text / markdown
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  org           Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fixture       Fixture        @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  merchandise   Merchandise[]
  exampleImages ExampleImage[]

  @@unique([campaignId, fixtureId])
  @@index([campaignId])
}

// Product catalog (connected to the buying/allocation source).
model Product {
  id        String   @id @default(cuid())
  orgId     String
  sku       String
  name      String   // the VM-guide label (e.g. "LE CON MINI CASS 160ML TEA")
  webTitle  String?  // full retail title from baccarat.com.au
  brand     String?
  range     String?  // Baccarat range: "Le Connoisseur", "Nook", "Iconix"…
  category  String?
  color     String?
  imageUrl  String?
  rrp       Float?   // recommended retail price
  salePrice Float?   // current sale/ticket price — the per-unit price sales log against
  createdAt DateTime @default(now())

  org             Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  merchandise     Merchandise[]
  salesEntries    SalesEntry[]
  fixtureDefaults FixtureProduct[]

  @@unique([orgId, sku])
  @@index([orgId])
}

// A default product on a library fixture — the reusable "what goes on this
// fixture" set (e.g. a Nook cookware setup). Copied onto a guide-fixture's
// merchandise when the author chooses to pre-populate, rather than start blank.
model FixtureProduct {
  id        String   @id @default(cuid())
  orgId     String
  fixtureId String
  productId String
  row       String? // optional planogram row grouping, mirrors Merchandise.row
  order     Int      @default(0)
  createdAt DateTime @default(now())

  org     Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([fixtureId, productId])
  @@index([fixtureId])
}

// A product merchandised onto a guide-fixture (with a row grouping like the demo).
model Merchandise {
  id             String   @id @default(cuid())
  orgId          String
  guideFixtureId String
  productId      String
  row            String?  // "Top rack", "New row", ...
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  org          Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  guideFixture GuideFixture @relation(fields: [guideFixtureId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([guideFixtureId])
}

// The VM-team example image(s) for a guide-fixture ("what good looks like").
model ExampleImage {
  id             String   @id @default(cuid())
  orgId          String
  guideFixtureId String
  storageKey     String
  caption        String?
  bestInClass    Boolean  @default(false)
  createdAt      DateTime @default(now())

  guideFixture GuideFixture @relation(fields: [guideFixtureId], references: [id], onDelete: Cascade)

  @@index([guideFixtureId])
}

// ═══════════════════════════════════════════ STORE-MANAGER workspace
// Tasks an admin assigns to a store (its manager): capture a photo, log sales,
// or a general ask. The manager's home shows OPEN tasks; `seenAt` drives the
// unread notification badge. SalesEntry is the manager's per-product sales log
// for a campaign period; it rolls up to the fixture (and the Money Map).

enum TaskKind {
  UPLOAD_PHOTO // capture/upload a fixture photo into the checklist
  LOG_SALES // log sales for the period
  GENERAL // free-form ask
}

enum TaskStatus {
  OPEN
  DONE
}

model Task {
  id          String     @id @default(cuid())
  orgId       String
  storeId     String // the store (its manager) the task is assigned to
  campaignId  String?
  kind        TaskKind   @default(GENERAL)
  status      TaskStatus @default(OPEN)
  title       String
  body        String? // what the admin is asking for
  fixtureKey  String? // for UPLOAD_PHOTO: which fixture
  dueAt       DateTime?
  seenAt      DateTime? // when the manager first opened it (notification badge)
  completedAt DateTime?
  createdAt   DateTime   @default(now())

  org      Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([orgId])
}

// One running sales tally per (store, campaign, product): units sold × the
// unit price snapshot = revenue. `fixtureId` is denormalised from the product's
// placement so the Money Map rolls up by fixture with a simple groupBy.
model SalesEntry {
  id         String   @id @default(cuid())
  orgId      String
  storeId    String
  campaignId String
  productId  String
  fixtureId  String?
  units      Int      @default(0)
  unitPrice  Float    @default(0) // price snapshot at log time
  revenue    Float    @default(0) // units × unitPrice, stored for fast rollups
  soldOn     DateTime @default(now()) @db.Date // the sale DAY (date-only); one entry per product per day
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, campaignId, productId, soldOn])
  @@index([storeId, campaignId, soldOn])
  @@index([campaignId, fixtureId])
}

// The store-manager compliance loop on the floor map. One row per
// (store, campaign, fixture): whether a photo is wanted this sale, the photo
// the manager submitted, and the AI verdict from comparing it to the guide's
// reference image + VM notes. Distinct from the legacy Submission/Photo pipeline
// (which is keyed by generic fixtureKey) — this is fixture-on-the-floor-plan.
enum CaptureVerdict {
  PASS
  NEEDS_REVIEW
  FAIL
}

model FixtureCapture {
  id         String          @id @default(cuid())
  orgId      String
  storeId    String
  campaignId String
  fixtureId  String
  needsPhoto Boolean         @default(true) // requested this sale / by a reviewer
  storageKey String? // the manager's uploaded photo
  uploadedAt DateTime?
  verdict    CaptureVerdict?
  aiNotes    String? // the model's compare notes
  confidence Float?
  modelId    String? // e.g. "gemini-2.5-flash" or "stub"
  scoredAt   DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  org      Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fixture  Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@unique([storeId, campaignId, fixtureId])
  @@index([storeId, campaignId])
}

// ═══════════════════════════════════════════ BULLETINS
// The per-sale memo that ships with each promotion (like the real "BULLETIN 89"):
// an admin authors it for a project (title + body + key dates + an optional PDF/
// image attachment), publishes it, and every store manager in the project must
// read + acknowledge it. A feed (newest first; pin the important ones).

model Bulletin {
  id             String    @id @default(cuid())
  orgId          String
  projectId      String
  campaignId     String? // the sale this belongs to (the project's active campaign)
  title          String
  body           String    @default("") // markdown
  pinned         Boolean   @default(false)
  startsAt       DateTime?
  endsAt         DateTime?
  attachmentKey  String? // storage key of the attached PDF / image
  attachmentName String?
  publishedAt    DateTime? // null = draft
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  org     Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  acks    BulletinAck[]

  @@index([projectId])
  @@index([orgId])
}

// One store manager's acknowledgement of a bulletin (the read receipt).
model BulletinAck {
  id             String   @id @default(cuid())
  bulletinId     String
  storeId        String
  userId         String
  acknowledgedAt DateTime @default(now())

  bulletin Bulletin @relation(fields: [bulletinId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([bulletinId, storeId])
  @@index([bulletinId])
}
