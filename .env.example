# Copy to apps/api/.env for local dev.
NODE_ENV=development

# Database (matches infra/docker-compose.yml — Postgres on high port 5434)
DATABASE_URL=postgresql://wally:wally_dev_pw@localhost:5434/wally?schema=public

# Auth
JWT_SECRET=dev_only_change_me_min_32_chars_xxxxx
SESSION_COOKIE_NAME=wally_session
SESSION_COOKIE_SECURE=false          # true in production
MAGIC_LINK_TTL_MIN=20
APP_URL=http://localhost:5173
APP_URL_API=http://localhost:3001/api   # absolute base for signed photo URLs (web :5173 -> api :3001)

# Google OAuth (reviewers). Leave blank in dev to use the dev-login bypass.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vision model (scoring).
#   anthropic = hosted Claude (needs ANTHROPIC_API_KEY).
#   ollama    = local, offline, vision-capable model — no cloud key, image bytes
#               never leave the machine. Needs a running Ollama daemon with a
#               vision model pulled (e.g. `ollama pull qwen2.5vl:7b`).
WALLY_VISION_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Leave WALLY_VISION_MODEL blank to use the provider default
# (claude-sonnet-4-6 for anthropic, qwen2.5vl:7b for ollama).
WALLY_VISION_MODEL=
# Local Ollama daemon endpoint (only used when WALLY_VISION_PROVIDER=ollama).
OLLAMA_HOST=http://localhost:11434
WALLY_CONFIDENCE_FLOOR=0.7

# Floor-map compliance compare (manager loop) also honours WALLY_VISION_PROVIDER:
# ollama -> local model above; else GEMINI_API_KEY -> Gemini; else a deterministic stub.
GEMINI_API_KEY=

# Mail (magic links) — Mailhog in dev
SMTP_HOST=localhost
SMTP_PORT=1026
MAIL_FROM=wally@thecookwarecompany.com

# Photo storage. local = disk (apps/api/storage); railway = Railway Volume mount
WALLY_STORAGE_DRIVER=local
WALLY_STORAGE_DIR=./storage
